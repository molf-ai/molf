{
  "name": "molf",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:unit": "vitest run packages/protocol/tests/ packages/agent-core/tests/ packages/server/tests/ packages/worker/tests/ packages/plugin-cron/tests/ packages/client-tui/tests/ packages/client-telegram/tests/ packages/plugin-mcp/tests/unit/",
    "test:e2e": "vitest run packages/e2e/tests/integration/ packages/plugin-mcp/tests/integration/",
    "test:live": "vitest run packages/e2e/tests/live/",
    "test:all": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --bail 1",
    "dev": "tsx --env-file-if-exists=.env scripts/dev.ts",
    "dev:client-tui": "tsx --env-file-if-exists=.env packages/client-tui/src/index.ts",
    "dev:client-telegram": "tsx --env-file-if-exists=.env packages/client-telegram/src/index.ts",
    "dev:server": "tsx --env-file-if-exists=.env packages/server/src/main.ts -- --data-dir data/server",
    "dev:pair": "tsx --env-file-if-exists=.env packages/server/src/main.ts -- pair",
    "dev:keys": "tsx --env-file-if-exists=.env packages/server/src/main.ts -- keys",
    "dev:worker": "tsx --env-file-if-exists=.env packages/worker/src/index.ts -- --workdir data/worker",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/which": "^3.0.4",
    "@vitest/coverage-v8": "^3.1.0",
    "fast-glob": "^3.3.3",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitepress": "^2.0.0-alpha.16",
    "vitest": "^3.1.0",
    "which": "^5.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.32.0+sha512.9b2634bb3fed5601c33633f2d92593f506270a3963b8c51d2b2d6a828da615ce4e9deebef9614ccebbc13ac8d3c0f9c9ccceb583c69c8578436fa477dbb20d70"
}
